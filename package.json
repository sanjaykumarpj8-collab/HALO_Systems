{
  "name": "halo-stadium",
  "version": "1.0.0",
  "private": true,
  "description": "HALO — Multi-Agent Stadium Operations Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:command": "npm run dev --workspace=apps/command-center",
    "build:command": "npm run build --workspace=apps/command-center",
    "dev:staff": "npm run web --workspace=ratio-staff",
    "dev:fan": "npm run web --workspace=fifa-fan",
    "start:cli": "npx tsx cli.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
